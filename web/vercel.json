{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NEXTAUTH_URL": {
      "description": "URL for NextAuth",
      "value": "https://your-domain.vercel.app"
    },
    "NEXTAUTH_SECRET": {
      "description": "Secret key for NextAuth",
      "generator": "secret"
    },
    "OPENROUTER_API_KEY": {
      "description": "OpenRouter API key for free AI models (no refusals, good at coding)"
    }
  }
}
