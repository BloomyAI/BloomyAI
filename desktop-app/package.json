{
  "name": "bloomy-desktop",
  "version": "1.0.0",
  "description": "Bloomy AI Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.bloomy.desktop",
    "productName": "Bloomy AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "logo.png",
      "../web/.next/**/*",
      "../web/public/**/*",
      "../web/node_modules/**/*",
      "../web/package.json"
    ],
    "extraResources": [
      {
        "from": "../web",
        "to": "web",
        "filter": [
          ".next/**/*",
          "public/**/*",
          "node_modules/**/*",
          "package.json",
          "next.config.*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "logo.png"
    }
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  }
}
